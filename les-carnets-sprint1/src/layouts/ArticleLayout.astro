---
import BaseLayout from './BaseLayout.astro';
const { title, description, category, publishedAt, image, imageAlt, number, readingTime } = Astro.props;
const date = new Intl.DateTimeFormat('fr-FR', { dateStyle:'long' }).format(new Date(publishedAt));
---
<BaseLayout title={`${title} · Les Carnets`} description={description} image={image}>
  <header class="article-hero container">
    <a class="back-link" href="/">← Tous les Carnets</a>
    <div class="meta" style="justify-content:center;margin-top:2rem">
      {number && <span class="tag">Carnet n°{number}</span>}
      <span class="tag">{category}</span>
      <span>{date}</span>
      <span>{readingTime ?? '8 min'}</span>
    </div>
    <h1>{title}</h1>
    <p class="article-deck">{description}</p>
  </header>
  {image && <figure class="article-cover"><img src={image} alt={imageAlt ?? ''} /></figure>}
  <div class="article-shell">
    <article class="article-content"><slot /></article>
    <aside class="article-cta">
      <p class="eyebrow">Pour poursuivre</p>
      <h3>Ce texte fait écho à ce que vous vivez ?</h3>
      <p>Découvrez mes accompagnements en individuel, en couple ou à travers les médiations artistiques.</p>
      <a class="button" href="https://emilietreynetgestalt.com">Découvrir Tout part de toi →</a>
    </aside>
  </div>
</BaseLayout>
